{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "ThisIsAHighlySecureAndVeryLongSecretKeyThatIsAtLeastSixtyFourCharactersLong1234567890!",
    "Issuer": "IdentityService",
    "Audience": "FinanceAggregatorClients"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "api/v1/auth/{**remainder}" },
          { "RequestHeader": "X-Gateway-Enforced", "Set": "true" }
        ]
      },
      "wallet-route": {
        "ClusterId": "wallet-cluster",
        "AuthorizationPolicy": "Default",
        "Match": {
          "Path": "/api/v1/wallets/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "api/v1/wallets/{**remainder}" }
        ]
      },
      "wallet-hub-route": {
        "ClusterId": "wallet-cluster",
        "Match": {
          "Path": "/hubs/wallets/{**remainder}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5205/" 
          }
        }
      },
      "wallet-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5202/" 
          }
        }
      }
    }
  }
}
